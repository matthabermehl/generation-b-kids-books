{
  "name": "ai-childrens-book",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/cdk"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "openapi:generate": "pnpm --filter @book/api openapi:generate",
    "cdk:synth": "AWS_PROFILE=personal pnpm --filter @book/cdk cdk:synth",
    "cdk:diff": "AWS_PROFILE=personal pnpm --filter @book/cdk cdk:diff",
    "cdk:deploy:dev": "AWS_PROFILE=personal AWS_REGION=us-east-1 pnpm --filter @book/cdk cdk:deploy:dev && pnpm run deploy:web:dev",
    "dev:web": "pnpm --filter @book/web dev",
    "deploy:web:dev": "AWS_PROFILE=personal AWS_REGION=us-east-1 node ./scripts/ops/deploy-web.mjs",
    "ops:ssm:migrate-secure": "AWS_PROFILE=personal AWS_REGION=us-east-1 bash ./scripts/ops/migrate-ssm-params.sh",
    "ops:provider-smoke": "AWS_PROFILE=personal AWS_REGION=us-east-1 node ./scripts/ops/provider-connectivity-smoke.mjs",
    "ops:picture-book-smoke": "AWS_PROFILE=personal AWS_REGION=us-east-1 node ./scripts/ops/picture-book-smoke.mjs",
    "ops:story-only-markdown": "pnpm --filter @book/workers build && AWS_PROFILE=personal AWS_REGION=us-east-1 node ./scripts/ops/story-only-markdown.mjs",
    "ops:stripe-smoke": "AWS_PROFILE=personal AWS_REGION=us-east-1 node ./scripts/ops/stripe-smoke.mjs",
    "ops:phase2-e2e": "AWS_PROFILE=personal AWS_REGION=us-east-1 node ./scripts/ops/phase2-e2e-smoke.mjs"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.750.0",
    "@aws-sdk/client-rds-data": "^3.750.0",
    "@aws-sdk/client-ssm": "^3.750.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
