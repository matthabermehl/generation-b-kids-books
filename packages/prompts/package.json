{
  "name": "@book/prompts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm --filter @book/domain build && tsc -p tsconfig.json",
    "lint": "pnpm --filter @book/domain build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @book/domain build && vitest run",
    "format": "echo 'format: @book/prompts no-op'"
  },
  "dependencies": {
    "@book/domain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
