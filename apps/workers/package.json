{
  "name": "@book/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @book/domain build && pnpm --filter @book/prompts build && tsc -p tsconfig.json",
    "lint": "pnpm --filter @book/domain build && pnpm --filter @book/prompts build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @book/domain build && pnpm --filter @book/prompts build && vitest run",
    "format": "echo 'format: @book/workers no-op'"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.750.0",
    "@aws-sdk/client-rds-data": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/client-sfn": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/client-ssm": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@book/domain": "workspace:*",
    "@book/prompts": "workspace:*",
    "pdfkit": "^0.15.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/pdfkit": "^0.17.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
