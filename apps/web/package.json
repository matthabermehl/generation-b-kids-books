{
  "name": "@book/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:api-types": "pnpm --filter @book/api openapi:generate && openapi-typescript ../api/openapi.json -o src/lib/api/generated.ts",
    "dev": "pnpm run generate:api-types && vite",
    "build": "pnpm run generate:api-types && vite build",
    "preview": "vite preview",
    "lint": "pnpm run generate:api-types && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run generate:api-types && vitest run",
    "format": "echo 'format: @book/web no-op'"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.6.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.14",
    "vitest": "^2.1.9"
  }
}
