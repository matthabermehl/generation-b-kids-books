    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@book/domain": "workspace:*",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/jsonwebtoken": "^9.0.9",
    "typescript": "^5.8.2",
